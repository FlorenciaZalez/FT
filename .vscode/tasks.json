{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Infra local",
      "type": "shell",
      "command": "/Applications/Docker.app/Contents/Resources/bin/docker",
      "args": [
        "compose",
        "up",
        "-d",
        "db",
        "redis"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Migraciones local",
      "type": "shell",
      "command": "./.venv/bin/python",
      "args": [
        "-m",
        "alembic",
        "upgrade",
        "head"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend local",
      "type": "shell",
      "command": "./.venv/bin/python",
      "args": [
        "-m",
        "uvicorn",
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend local",
      "type": "shell",
      "command": "/Users/florenciazalez/.nvm/versions/node/v24.14.1/bin/node",
      "args": [
        "/Users/florenciazalez/.nvm/versions/node/v24.14.1/lib/node_modules/npm/bin/npm-cli.js",
        "run",
        "dev",
        "--",
        "--host",
        "127.0.0.1"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": {
          "PATH": "/Users/florenciazalez/.nvm/versions/node/v24.14.1/bin:${env:PATH}"
        }
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}