# Database
DATABASE_URL=postgresql+asyncpg://stock_user:stock_pass@localhost:5432/stock_db

# JWT
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
DEBUG=true

# MercadoLibre OAuth
ML_CLIENT_ID=TU_CLIENT_ID_AQUI
ML_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI
ML_REDIRECT_URI=http://localhost:5173/integrations/ml/callback
